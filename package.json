{
  "name": "@shipitandpray/pretext-epub",
  "version": "1.0.0",
  "description": "EPUB pagination engine with instant page jumps and accurate progress tracking. Powered by @chenglou/pretext for exact page break computation.",
  "author": "ShipItAndPray",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./reader": {
      "types": "./dist/reader.d.ts",
      "import": "./dist/reader.js",
      "require": "./dist/reader.cjs"
    },
    "./css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@chenglou/pretext": ">=0.0.3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "fast-xml-parser": "^4.3.0"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^24.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "epub",
    "ebook",
    "pagination",
    "reader",
    "pretext",
    "react",
    "page-break",
    "progress",
    "widow-orphan"
  ]
}
